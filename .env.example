# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============================================
# Database (MySQL 8)
# ============================================
DATABASE_URL=mysql://root:password@localhost:3306/j_commerce
DATABASE_URL_TEST=mysql://root:password@localhost:3306/j_commerce_test

# ============================================
# JWT Auth
# ============================================
# Min 32 chars! Use openssl rand -base64 32 to generate
JWT_SECRET=change-me-to-a-secure-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change-me-to-another-secure-random-secret-32
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# Midtrans Sandbox
# Get keys at https://dashboard.sandbox.midtrans.com/settings/access-keys
# ============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXX
MIDTRANS_IS_PRODUCTION=false

# ============================================
# File Upload
# ============================================
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=5
BASE_URL=http://localhost:3000

# ============================================
# Rate Limiting
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100
